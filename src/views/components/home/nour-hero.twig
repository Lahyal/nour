<section style="min-height:80vh;background:#1E3A2F;display:flex;align-items:center;justify-content:center;padding:60px;text-align:center;">
  <div>
    <h1 style="font-size:48px;font-weight:900;color:#FAF8F4;margin-bottom:20px;">
      {{ component.heading | default('مرحباً بك') }}
    </h1>
    <p style="font-size:18px;color:rgba(250,248,244,.7);margin-bottom:32px;">
      {{ component.subheading | default('') }}
    </p>
    <a href="{{ store.urls.products }}" style="background:#C8A876;color:#1E3A2F;padding:14px 32px;border-radius:8px;font-size:16px;font-weight:800;text-decoration:none;display:inline-block;">
      {{ component.btn_primary_text | default('اطلبي الآن') }}
    </a>
  </div>
</section>
