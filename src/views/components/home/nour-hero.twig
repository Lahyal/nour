<section class="s-block wide-placeholder" style="background:#1E3A2F;min-height:500px;display:flex;align-items:center;justify-content:center;padding:60px;">
  <div style="color:white;text-align:center;">
    <h1 style="font-size:48px;font-weight:900;margin-bottom:20px;">{{ component.heading }}</h1>
    <p style="font-size:20px;opacity:0.8;">{{ component.subheading }}</p>
    <a href="{{ store.urls.products }}" style="display:inline-block;margin-top:30px;background:#C8A876;color:#1E3A2F;padding:16px 40px;border-radius:8px;font-weight:800;font-size:18px;text-decoration:none;">{{ component.btn_primary_text }}</a>
  </div>
</section>
