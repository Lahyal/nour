{#
| component.heading | string     | Section title
| component.tag     | string     | Badge
| component.reviews | collection | {reviews.name, reviews.rating, reviews.title, reviews.text}
#}
<section class="s-block nour-testimonials container">
  {% if component.tag %}
    <span class="nour-tag">{{ component.tag }}</span>
  {% endif %}
  <h2 class="nour-section-title">{{ component.heading | default('ماذا يقول عملاؤنا؟') }}</h2>
  <div class="nour-tc-grid">
    {% for review in component.reviews %}
      <div class="nour-tc">
        <div class="nour-tc__header">
          <div class="nour-tc__av">{{ review['reviews.name'] | default(review.name) | slice(0,1) }}</div>
          <div>
            <div class="nour-tc__name">{{ review['reviews.name'] | default(review.name) }}</div>
            <div class="nour-tc__meta">مشتري موثّق</div>
          </div>
          <div class="nour-tc__stars">
            {% set rating = review['reviews.rating'] | default(review.rating) | default(5) %}
            {% for i in 1..5 %}{% if i <= rating %}★{% else %}☆{% endif %}{% endfor %}
          </div>
        </div>
        {% if review['reviews.title'] | default(review.title) %}
          <div class="nour-tc__title">{{ review['reviews.title'] | default(review.title) }}</div>
        {% endif %}
        <div class="nour-tc__text">"{{ review['reviews.text'] | default(review.text) }}"</div>
      </div>
    {% endfor %}
  </div>
</section>
