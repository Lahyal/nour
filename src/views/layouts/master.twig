<!DOCTYPE html>
<html lang="{{ store.language.code }}" dir="{{ store.language.direction }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ store.name }}{% endblock %}</title>
  <meta name="description" content="{% block description %}{{ store.description }}{% endblock %}">

  {# Fonts #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family={{ settings.font_main | default('Tajawal') }}:wght@300;400;500;700;800;900&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">

  {# Hugeicons #}
  <link rel="stylesheet" href="https://cdn.hugeicons.com/font/hgi-stroke-rounded.css">

  {# Theme CSS #}
  <link rel="stylesheet" href="{{ 'css/theme.css' | asset_url }}">

  {# CSS Variables from settings #}
  <style>
    :root {
      --color-primary:   {{ settings.color_primary | default('#1E3A2F') }};
      --color-accent:    {{ settings.color_accent  | default('#C8A876') }};
      --color-bg:        {{ settings.color_bg      | default('#FAF8F4') }};
      --font-main:       '{{ settings.font_main    | default('Tajawal') }}', sans-serif;
    }
  </style>

  {% block extra_head %}{% endblock %}
  {% hook 'head:end' %}
</head>
<body class="{% if settings.topnav_is_dark %}header-dark{% endif %}">

  {# Announcement Bar #}
  {% if settings.announcement_visible %}
    {% include 'partials/announcement' %}
  {% endif %}

  {# Header #}
  {% include 'partials/header' %}

  {# Page Content #}
  <main id="main-content">
    {% block content %}{% endblock %}
  </main>

  {# Footer #}
  {% include 'partials/footer' %}

  {# Sticky Cart Bar #}
  {% block sticky_bar %}{% endblock %}

  {# Scripts #}
  <script src="{{ 'js/theme.js' | asset_url }}" defer></script>
  {% block extra_scripts %}{% endblock %}
  {% hook 'body:end' %}
</body>
</html>
