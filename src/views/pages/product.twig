{% extends 'layouts/master' %}

{% set product = pages.product %}

{% block title %}{{ product.name }} — {{ store.name }}{% endblock %}
{% block description %}{{ product.description | striptags | slice(0, 160) }}{% endblock %}

{% block content %}

{# Breadcrumb #}
<nav class="breadcrumb">
  <a href="{{ store.url }}">{{ 'الرئيسية' | trans }}</a>
  <span class="sep">›</span>
  <a href="{{ product.category.url }}">{{ product.category.name }}</a>
  <span class="sep">›</span>
  <span class="current">{{ product.name }}</span>
</nav>

{# Product Hero #}
<div class="product-hero">

  {# ── GALLERY ── #}
  <div class="gallery-col">
    <div class="main-img-track" id="mainImgTrack">

      {% if product.has_special_price %}
        <span class="img-label-sale">
          {% if product.offer.percent %}
            خصم {{ product.offer.percent }}%
          {% else %}
            عرض خاص
          {% endif %}
        </span>
      {% endif %}

      {% if product.is_bestseller %}
        <span class="img-label-top">{{ 'الأكثر مبيعاً' | trans }}</span>
      {% endif %}

      {# Main Image #}
      {% if product.images | length > 0 %}
        <img src="{{ product.images[0].url }}"
             alt="{{ product.name }}"
             id="mainProductImg"
             loading="eager">
      {% else %}
        <img src="{{ settings.placeholder | asset_url }}"
             alt="{{ product.name }}"
             id="mainProductImg">
      {% endif %}

      {# Image nav dots #}
      {% if product.images | length > 1 %}
        <div class="img-nav">
          {% for image in product.images %}
            <button class="img-dot {% if loop.first %}active{% endif %}"
                    onclick="goSlide({{ loop.index0 }}, this)"></button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {# Thumbnails #}
    {% if product.images | length > 1 %}
      <div class="thumbs">
        {% for image in product.images %}
          <div class="thumb {% if loop.first %}active{% endif %}"
               onclick="switchThumb(this, '{{ image.url }}')">
            <img src="{{ image.url }}" alt="{{ product.name }} - {{ loop.index }}" loading="lazy">
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  {# ── PRODUCT INFO ── #}
  <div class="info-col">

    {# Social Proof Row #}
    {% if settings.show_rating_in_header and product.rating.count > 0 %}
      <div class="social-proof-row">
        <div class="sp-avatars">
          <span>أ</span><span>م</span><span>ن</span><span>ر</span>
        </div>
        <div class="sp-text">
          <strong>{{ product.rating.count | number_format }} {{ 'عميل' | trans }}</strong>
          {{ 'اشتروا هذا المنتج' | trans }}
        </div>
      </div>
    {% endif %}

    {# Title #}
    <h1 class="product-title">{{ product.name }}</h1>
    {% if product.subtitle %}
      <p class="product-subtitle">{{ product.subtitle }}</p>
    {% endif %}

    {# Rating #}
    {% if product.rating.count > 0 %}
      <div class="rating-bar">
        <span class="stars-gold">
          {% for i in 1..5 %}
            {% if i <= product.rating.average %}★{% else %}☆{% endif %}
          {% endfor %}
        </span>
        <span class="rating-num">{{ product.rating.average }}</span>
        <span class="rating-count">
          <a href="#reviews">{{ product.rating.count }} {{ 'تقييم' | trans }}</a>
        </span>
        <span class="rating-badge">94% {{ 'يوصون به' | trans }}</span>
      </div>
    {% endif %}

    {# Benefit Pills — from product tags #}
    {% if product.tags | length > 0 %}
      <div class="benefit-pills">
        {% for tag in product.tags | slice(0, 4) %}
          <div class="bpill">
            <i class="hgi-stroke hgi-checkmark-circle-01 icon-xs"></i>
            {{ tag.name }}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {# ── PRICE BLOCK ── #}
    <div class="price-block">
      <div class="price-row">
        <span class="price-now" id="priceNow">{{ product.price.amount }}</span>
        <span class="price-currency">{{ product.price.currency }}</span>
        {% if product.has_special_price %}
          <span class="price-was">{{ product.regular_price.formatted }}</span>
          {% if product.offer.percent %}
            <span class="price-save">{{ 'وفري' | trans }} {{ product.offer.percent }}%</span>
          {% endif %}
        {% endif %}
      </div>
      <div class="stock-row">
        <span class="stock-dot"></span>
        {% if product.quantity > 0 %}
          {{ 'متوفر' | trans }}
          {% if product.quantity <= 10 %}
            — {{ product.quantity }} {{ 'قطعة متبقية فقط' | trans }}
          {% endif %}
        {% else %}
          {{ 'نفد المخزون' | trans }}
        {% endif %}
      </div>
    </div>

    {# ── BUNDLE OPTIONS ── #}
    {% if settings.bundle_enabled and product.has_special_price %}
      {% component 'product.nour-bundle-options' %}
    {% endif %}

    {# ── SUBSCRIPTION TOGGLE ── #}
    {% if settings.subscription_enabled %}
      <div class="sub-card">
        <div class="sub-option selected" id="subOnce" onclick="selectSub('once')">
          <div class="sub-radio" id="radioOnce"></div>
          <div class="sub-body">
            <div class="sub-name">{{ 'شراء مرة واحدة' | trans }}</div>
            <div class="sub-desc">{{ product.price.formatted }} — {{ 'شحن مجاني' | trans }}</div>
          </div>
        </div>
        <div class="sub-option" id="subRecurring" onclick="selectSub('recurring')">
          <div class="sub-radio" id="radioRecurring"></div>
          <div class="sub-body">
            <div class="sub-name">
              <i class="hgi-stroke hgi-refresh icon-xs"></i>
              {{ 'اشتركي واوفري كل شهر' | trans }}
            </div>
            <div class="sub-desc">
              {{ 'وفري' | trans }} {{ settings.subscription_discount }}%
              — {{ 'ألغي في أي وقت' | trans }}
            </div>
          </div>
          <span class="sub-badge">{{ 'وفري' | trans }} {{ settings.subscription_discount }}%</span>
        </div>
      </div>
    {% endif %}

    {# ── VARIANTS ── #}
    {% if product.options | length > 0 %}
      {% for option in product.options %}
        <div class="field-label">
          {{ option.name }}:
          <span id="variantLabel-{{ option.id }}">{{ option.values[0].name }}</span>
        </div>
        <div class="variants">
          {% for value in option.values %}
            <button class="vbtn {% if loop.first %}active{% endif %} {% if not value.is_available %}out{% endif %}"
                    onclick="selectVariant(this, '{{ value.name }}', '{{ option.id }}')"
                    data-option="{{ option.id }}"
                    data-value="{{ value.id }}">
              {{ value.name }}
            </button>
          {% endfor %}
        </div>
      {% endfor %}
    {% endif %}

    {# ── QUANTITY ── #}
    <div class="qty-row">
      <div class="qty-ctrl">
        <button class="qty-btn" onclick="chQty(-1)">−</button>
        <input class="qty-val" type="number" id="qtyVal" value="1" min="1"
               max="{{ product.quantity }}" name="quantity">
        <button class="qty-btn" onclick="chQty(1)">+</button>
      </div>
      <div class="subtotal-txt">
        {{ 'المجموع' | trans }}:
        <strong id="subtotalDisplay">{{ product.price.formatted }}</strong>
      </div>
    </div>

    {# ── CTA BUTTONS ── #}
    <div class="cta-stack">
      {% if product.quantity > 0 %}
        <salla-add-product-button id="addBtn"
          product-id="{{ product.id }}"
          class="btn-main">
          <i class="hgi-stroke hgi-shopping-cart-01"></i>
          {{ 'أضيفي للسلة' | trans }}
        </salla-add-product-button>
      {% else %}
        <button class="btn-main" disabled>{{ 'نفد المخزون' | trans }}</button>
      {% endif %}
      <salla-buy-now-button product-id="{{ product.id }}" class="btn-gold">
        <i class="hgi-stroke hgi-zap"></i>
        {{ 'اشتري الآن' | trans }}
      </salla-buy-now-button>
    </div>

    {# Recent buyers #}
    {% if settings.show_recent_buyers %}
      <div class="recent-buyers">
        <i class="hgi-stroke hgi-fire icon-sm" style="color:var(--gold-dark)"></i>
        <div class="rb-avs">
          <div class="rb-av">أ</div>
          <div class="rb-av">ف</div>
          <div class="rb-av">ه</div>
        </div>
        <span>{{ 'منذ ساعة — مشتريات جديدة' | trans }}</span>
      </div>
    {% endif %}

    {# Payment Methods #}
    <salla-payment-icons></salla-payment-icons>

    {# Trust Row #}
    <div class="trust-mini">
      <div class="tm-item">
        <i class="hgi-stroke hgi-truck icon-sm"></i>
        {{ 'شحن مجاني' | trans }}
      </div>
      <div class="tm-item">
        <i class="hgi-stroke hgi-return-request icon-sm"></i>
        {{ 'إرجاع 30 يوم' | trans }}
      </div>
      <div class="tm-item">
        <i class="hgi-stroke hgi-lock icon-sm"></i>
        {{ 'دفع آمن' | trans }}
      </div>
      <div class="tm-item">
        <i class="hgi-stroke hgi-gift icon-sm"></i>
        {{ 'تغليف فاخر' | trans }}
      </div>
    </div>

    {# ── ACCORDION ── #}
    <div class="acc-list">

      {# Ingredients / Description #}
      {% if product.description %}
        <div class="acc-item">
          <button class="acc-head" onclick="toggleAcc(this)">
            {{ 'تفاصيل المنتج' | trans }}
            <span class="acc-icon">+</span>
          </button>
          <div class="acc-body">
            {{ product.description | raw }}
          </div>
        </div>
      {% endif %}

      {# Shipping #}
      <div class="acc-item">
        <button class="acc-head" onclick="toggleAcc(this)">
          {{ 'الشحن والإرجاع' | trans }}
          <span class="acc-icon">+</span>
        </button>
        <div class="acc-body">
          <div style="display:flex;flex-direction:column;gap:8px">
            <div style="display:flex;gap:10px;align-items:center">
              <i class="hgi-stroke hgi-truck icon-sm" style="color:var(--color-primary);flex-shrink:0"></i>
              {{ 'شحن مجاني للطلبات فوق 200 ر.س' | trans }}
            </div>
            <div style="display:flex;gap:10px;align-items:center">
              <i class="hgi-stroke hgi-clock-01 icon-sm" style="color:var(--color-primary);flex-shrink:0"></i>
              {{ 'التوصيل خلال 2-3 أيام عمل' | trans }}
            </div>
            <div style="display:flex;gap:10px;align-items:center">
              <i class="hgi-stroke hgi-return-request icon-sm" style="color:var(--color-primary);flex-shrink:0"></i>
              {{ 'إرجاع مجاني خلال 30 يوم' | trans }}
            </div>
          </div>
        </div>
      </div>

    </div>

  </div>
</div>

{# ── BELOW THE FOLD SECTIONS ── #}

{# Full-width Lifestyle Image #}
{% if product.images | length > 2 %}
  <div class="fw-section">
    <img src="{{ product.images[2].url }}" alt="{{ product.name }}" loading="lazy">
    <div class="fw-overlay"></div>
  </div>
{% endif %}

{# Product Reviews #}
<div class="reviews-section" id="reviews">
  <salla-rating-stars product-id="{{ product.id }}"></salla-rating-stars>
  <salla-reviews product-id="{{ product.id }}"></salla-reviews>
</div>

{# Related Products #}
{% if product.related_products | length > 0 %}
  <div class="related-section">
    <span class="section-tag">{{ 'قد يعجبك أيضاً' | trans }}</span>
    <h2 class="section-h2">{{ 'منتجات' | trans }} <em>{{ 'مكمّلة' | trans }}</em></h2>
    <div class="related-grid">
      {% for related in product.related_products | slice(0, 3) %}
        {% include 'partials/product-card' with { product: related } %}
      {% endfor %}
    </div>
  </div>
{% endif %}

{% endblock %}

{# ── STICKY BAR ── #}
{% block sticky_bar %}
  <div class="sticky-bar" id="stickyBar">
    <div class="sb-product">
      <div class="sb-thumb">
        {% if product.images | length > 0 %}
          <img src="{{ product.images[0].url }}" alt="{{ product.name }}">
        {% else %}
          <i class="hgi-stroke hgi-package-01" style="font-size:22px;color:var(--gold-light)"></i>
        {% endif %}
      </div>
      <div>
        <div class="sb-name">{{ product.name }}</div>
        <div class="sb-price">{{ product.price.formatted }}</div>
      </div>
    </div>
    <div class="sb-right">
      {% if product.rating.count > 0 %}
        <div class="sb-stars">
          ★★★★★ {{ product.rating.average }}
        </div>
      {% endif %}
      <salla-add-product-button product-id="{{ product.id }}" class="sb-btn">
        <i class="hgi-stroke hgi-shopping-cart-01" style="font-size:16px"></i>
        {{ 'أضيفي للسلة' | trans }}
      </salla-add-product-button>
    </div>
  </div>
{% endblock %}

{% block extra_scripts %}
<script>
// Gallery
function switchThumb(thumb, imgUrl){
  document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
  thumb.classList.add('active');
  document.getElementById('mainProductImg').src = imgUrl;
}
function goSlide(idx, dot){
  document.querySelectorAll('.img-dot').forEach(d => d.classList.remove('active'));
  dot.classList.add('active');
  document.querySelectorAll('.thumb')[idx]?.click();
}

// Accordion
function toggleAcc(btn){
  const body = btn.nextElementSibling;
  const icon = btn.querySelector('.acc-icon');
  const open = body.classList.contains('open');
  document.querySelectorAll('.acc-body').forEach(b => b.classList.remove('open'));
  document.querySelectorAll('.acc-head').forEach(h => { h.classList.remove('open'); h.querySelector('.acc-icon').textContent = '+'; });
  if(!open){ body.classList.add('open'); btn.classList.add('open'); icon.textContent = '−'; }
}

// Qty
function chQty(d){
  const input = document.getElementById('qtyVal');
  const max = parseInt(input.max) || 99;
  input.value = Math.max(1, Math.min(max, parseInt(input.value) + d));
  updateSubtotal();
}
function updateSubtotal(){
  const basePrice = {{ product.price.amount }};
  const qty = parseInt(document.getElementById('qtyVal').value) || 1;
  document.getElementById('subtotalDisplay').textContent = (basePrice * qty).toFixed(2) + ' {{ product.price.currency }}';
}

// Subscription
function selectSub(type){
  document.getElementById('subOnce').className = 'sub-option' + (type === 'once' ? ' selected' : '');
  document.getElementById('subRecurring').className = 'sub-option' + (type === 'recurring' ? ' selected' : '');
  document.getElementById('radioOnce').className = 'sub-radio' + (type === 'once' ? ' selected' : '');
  document.getElementById('radioRecurring').className = 'sub-radio' + (type === 'recurring' ? ' selected' : '');
}

// Sticky bar
window.addEventListener('scroll', () => {
  const hero = document.querySelector('.product-hero');
  const bar = document.getElementById('stickyBar');
  if(bar && hero) bar.classList.toggle('show', hero.getBoundingClientRect().bottom < 0);
});

// Mobile menu
function toggleMenu(){
  document.getElementById('mobileMenu').classList.toggle('open');
  document.getElementById('hamburger').classList.toggle('open');
}
function toggleSearch(){
  document.getElementById('searchBar').classList.toggle('open');
}
</script>
{% endblock %}
