{% extends 'layouts/master' %}
{% set product = pages.product %}
{% block title %}{{ product.name }} — {{ store.name }}{% endblock %}
{% block description %}{{ product.description | striptags | slice(0, 160) }}{% endblock %}

{% block content %}
<div class="nour-product-wrap container">
  <div class="nour-product-grid">

    {# ── GALLERY ── #}
    <div class="nour-gallery">
      <div class="nour-main-img" id="nourMainImg">
        {% if product.has_special_price %}
          <span class="nour-img-badge nour-img-badge--sale">
            {% if product.offer.percent %}خصم {{ product.offer.percent }}%{% else %}عرض خاص{% endif %}
          </span>
        {% endif %}
        {% if product.is_bestseller %}
          <span class="nour-img-badge nour-img-badge--top">الأكثر مبيعاً</span>
        {% endif %}
        <img src="{{ product.images[0].url | default(theme.settings.get('placeholder','')) }}"
             alt="{{ product.name }}" id="nourProductImg" loading="eager">
      </div>
      {% if product.images | length > 1 %}
        <div class="nour-thumbs">
          {% for image in product.images %}
            <div class="nour-thumb {% if loop.first %}active{% endif %}"
                 onclick="nourThumb(this,'{{ image.url }}')">
              <img src="{{ image.url }}" alt="{{ product.name }}" loading="lazy">
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    {# ── INFO ── #}
    <div class="nour-info">

      {# Social proof #}
      {% if product.rating.count > 0 %}
        <div class="nour-sp-row">
          <div class="nour-sp-avs">
            <span>أ</span><span>م</span><span>ن</span><span>ر</span>
          </div>
          <span class="nour-sp-txt">
            <strong>{{ product.rating.count }}</strong> عميل اشتروا هذا المنتج
          </span>
        </div>
      {% endif %}

      {# Title #}
      <h1 class="nour-product-title">{{ product.name }}</h1>
      {% if product.subtitle %}
        <p class="nour-product-sub">{{ product.subtitle }}</p>
      {% endif %}

      {# Rating #}
      {% if product.rating.count > 0 %}
        <div class="nour-rating-row">
          <span class="nour-stars">
            {% for i in 1..5 %}{% if i <= product.rating.average %}★{% else %}☆{% endif %}{% endfor %}
          </span>
          <span class="nour-rating-num">{{ product.rating.average }}</span>
          <a href="#reviews" class="nour-rating-count">{{ product.rating.count }} تقييم</a>
          <span class="nour-rating-badge">94% يوصون به</span>
        </div>
      {% endif %}

      {# Tags as benefit pills #}
      {% if product.tags | length > 0 %}
        <div class="nour-pills">
          {% for tag in product.tags | slice(0,4) %}
            <span class="nour-pill">✓ {{ tag.name }}</span>
          {% endfor %}
        </div>
      {% endif %}

      {# Price #}
      <div class="nour-price-block">
        <div class="nour-price-row">
          <span class="nour-price-now" id="nourPriceNow">{{ product.price.amount }}</span>
          <span class="nour-price-currency">{{ product.price.currency }}</span>
          {% if product.has_special_price %}
            <span class="nour-price-was">{{ product.regular_price.formatted }}</span>
            {% if product.offer.percent %}
              <span class="nour-price-save">وفري {{ product.offer.percent }}%</span>
            {% endif %}
          {% endif %}
        </div>
        <div class="nour-stock-row">
          <span class="nour-stock-dot {% if product.quantity <= 0 %}out{% endif %}"></span>
          {% if product.quantity > 0 %}
            متوفر{% if product.quantity <= 10 %} — {{ product.quantity }} قطعة متبقية فقط{% endif %}
          {% else %}
            نفد المخزون
          {% endif %}
        </div>
      </div>

      {# Bundle options #}
      {% if theme.settings.get('bundle_enabled', true) and product.has_special_price %}
        {% component 'product.nour-bundle-options' %}
      {% endif %}

      {# Subscription #}
      {% if theme.settings.get('subscription_enabled', false) %}
        <div class="nour-sub-card">
          <div class="nour-sub-option selected" id="nourSubOnce" onclick="nourSub('once')">
            <div class="nour-sub-radio" id="nourRadioOnce"></div>
            <div>
              <div class="nour-sub-name">شراء مرة واحدة</div>
              <div class="nour-sub-desc">{{ product.price.formatted }} — شحن مجاني</div>
            </div>
          </div>
          <div class="nour-sub-option" id="nourSubRec" onclick="nourSub('recurring')">
            <div class="nour-sub-radio" id="nourRadioRec"></div>
            <div>
              <div class="nour-sub-name">اشتركي واوفري كل شهر</div>
              <div class="nour-sub-desc">وفري {{ theme.settings.get('subscription_discount','15') }}% — ألغي في أي وقت</div>
            </div>
            <span class="nour-sub-badge">وفري {{ theme.settings.get('subscription_discount','15') }}%</span>
          </div>
        </div>
      {% endif %}

      {# Variants #}
      {% if product.options | length > 0 %}
        {% for option in product.options %}
          <div class="nour-field-label">{{ option.name }}: <span id="nourVar-{{ option.id }}">{{ option.values[0].name }}</span></div>
          <div class="nour-variants">
            {% for value in option.values %}
              <button class="nour-vbtn {% if loop.first %}active{% endif %} {% if not value.is_available %}out{% endif %}"
                      onclick="nourVariant(this,'{{ value.name }}','{{ option.id }}')"
                      data-option="{{ option.id }}" data-value="{{ value.id }}">
                {{ value.name }}
              </button>
            {% endfor %}
          </div>
        {% endfor %}
      {% endif %}

      {# Qty #}
      <div class="nour-qty-row">
        <div class="nour-qty-ctrl">
          <button class="nour-qty-btn" onclick="nourQty(-1)">−</button>
          <input class="nour-qty-val" type="number" id="nourQty" value="1" min="1" max="{{ product.quantity }}">
          <button class="nour-qty-btn" onclick="nourQty(1)">+</button>
        </div>
        <div class="nour-subtotal">المجموع: <strong id="nourSubtotal">{{ product.price.formatted }}</strong></div>
      </div>

      {# CTAs #}
      <div class="nour-cta-stack">
        {% if product.quantity > 0 %}
          <salla-add-product-button product-id="{{ product.id }}" class="nour-btn-add-cart">
            أضيفي للسلة
          </salla-add-product-button>
        {% else %}
          <button class="nour-btn-add-cart" disabled>نفد المخزون</button>
        {% endif %}
        <salla-buy-now-button product-id="{{ product.id }}" class="nour-btn-buy-now">
          اشتري الآن
        </salla-buy-now-button>
      </div>

      {# Recent buyers #}
      {% if theme.settings.get('show_recent_buyers', true) %}
        <div class="nour-recent-buyers">
          🔥 مشتريات جديدة منذ ساعة
        </div>
      {% endif %}

      {# Payment icons #}
      <salla-payment-icons></salla-payment-icons>

      {# Trust row #}
      <div class="nour-trust-mini">
        <div class="nour-tm-item">🚚 شحن مجاني</div>
        <div class="nour-tm-item">↩ إرجاع 30 يوم</div>
        <div class="nour-tm-item">🔒 دفع آمن</div>
        <div class="nour-tm-item">🎁 تغليف فاخر</div>
      </div>

      {# Accordion #}
      <div class="nour-acc-list">
        {% if product.description %}
          <div class="nour-acc-item">
            <button class="nour-acc-head" onclick="nourAcc(this)">
              تفاصيل المنتج <span class="nour-acc-icon">+</span>
            </button>
            <div class="nour-acc-body">{{ product.description | raw }}</div>
          </div>
        {% endif %}
        <div class="nour-acc-item">
          <button class="nour-acc-head" onclick="nourAcc(this)">
            الشحن والإرجاع <span class="nour-acc-icon">+</span>
          </button>
          <div class="nour-acc-body">
            <p>شحن مجاني للطلبات فوق 200 ر.س</p>
            <p>التوصيل خلال 2-3 أيام عمل</p>
            <p>إرجاع مجاني خلال 30 يوم</p>
          </div>
        </div>
      </div>

    </div>
  </div>

  {# Reviews #}
  <div class="nour-reviews-wrap" id="reviews">
    <salla-reviews product-id="{{ product.id }}"></salla-reviews>
  </div>

  {# Related products #}
  {% if product.related_products | length > 0 %}
    <div class="nour-related">
      <h2 class="nour-section-title">قد يعجبك أيضاً</h2>
      <div class="nour-related-grid">
        {% for related in product.related_products | slice(0,3) %}
          <a href="{{ related.url }}" class="nour-product-card">
            <div class="nour-product-card__img">
              <img src="{{ related.thumbnail }}" alt="{{ related.name }}" loading="lazy">
            </div>
            <div class="nour-product-card__body">
              <div class="nour-product-card__name">{{ related.name }}</div>
              <div class="nour-product-card__price">{{ related.price.formatted }}</div>
            </div>
          </a>
        {% endfor %}
      </div>
    </div>
  {% endif %}

</div>

{# Sticky bar #}
<div class="nour-sticky-bar" id="nourStickyBar">
  <div class="nour-sb-product">
    <div class="nour-sb-thumb">
      <img src="{{ product.images[0].url | default('') }}" alt="{{ product.name }}">
    </div>
    <div>
      <div class="nour-sb-name">{{ product.name }}</div>
      <div class="nour-sb-price">{{ product.price.formatted }}</div>
    </div>
  </div>
  <salla-add-product-button product-id="{{ product.id }}" class="nour-sb-btn">
    أضيفي للسلة
  </salla-add-product-button>
</div>

{% endblock %}

{% block scripts %}
{{ parent() }}
<script>
function nourThumb(el, url) {
  document.querySelectorAll('.nour-thumb').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('nourProductImg').src = url;
}
function nourQty(d) {
  var inp = document.getElementById('nourQty');
  inp.value = Math.max(1, Math.min(parseInt(inp.max)||99, parseInt(inp.value)+d));
  nourUpdateSubtotal();
}
function nourUpdateSubtotal() {
  var price = {{ product.price.amount }};
  var qty = parseInt(document.getElementById('nourQty').value)||1;
  document.getElementById('nourSubtotal').textContent = (price*qty).toFixed(2)+' {{ product.price.currency }}';
}
function nourSub(type) {
  ['nourSubOnce','nourSubRec'].forEach(function(id){
    document.getElementById(id).classList.remove('selected');
  });
  document.getElementById(type==='once'?'nourSubOnce':'nourSubRec').classList.add('selected');
}
function nourVariant(btn, name, optId) {
  document.querySelectorAll('.nour-vbtn[data-option="'+optId+'"]').forEach(function(b){ b.classList.remove('active'); });
  btn.classList.add('active');
  var lbl = document.getElementById('nourVar-'+optId);
  if(lbl) lbl.textContent = name;
}
function nourAcc(btn) {
  var body = btn.nextElementSibling;
  var icon = btn.querySelector('.nour-acc-icon');
  var isOpen = body.classList.contains('open');
  document.querySelectorAll('.nour-acc-body').forEach(function(b){ b.classList.remove('open'); });
  document.querySelectorAll('.nour-acc-head').forEach(function(h){ h.classList.remove('open'); var i=h.querySelector('.nour-acc-icon'); if(i)i.textContent='+'; });
  if(!isOpen){ body.classList.add('open'); btn.classList.add('open'); if(icon)icon.textContent='−'; }
}
window.addEventListener('scroll', function() {
  var bar = document.getElementById('nourStickyBar');
  var grid = document.querySelector('.nour-product-grid');
  if(bar && grid) bar.classList.toggle('show', grid.getBoundingClientRect().bottom < 0);
});
</script>
{% endblock %}
